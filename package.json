{
  "name": "ecom-project",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade ecommerce backend",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "lint": "tsc --noEmit",
    "worker:email": "tsx src/workers/email.worker.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx scripts/seed.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "test:all": "tsx scripts/run-tests.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "bullmq": "^5.56.9",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.8.1",
    "pg": "^8.16.3",
    "pino": "^9.10.0",
    "pino-pretty": "^13.1.2",
    "prom-client": "^15.1.3",
    "@prisma/client": "^6.7.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "prisma": "^6.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  }
}
